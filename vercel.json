{
  "ignoreCommand": "exit 1",
  "rewrites": [
    {
      "source": "/tproduct/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/woman",
      "destination": "/index.html"
    },
    {
      "source": "/woman/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/order",
      "destination": "/order.html"
    },
    {
      "source": "/feed.xml",
      "destination": "/api/feed"
    },
    {
      "source": "/api/feed.xml",
      "destination": "/api/feed"
    },
    {
      "source": "/sale-feed.xml",
      "destination": "/api/sale-feed"
    },
    {
      "source": "/api/sale-feed.xml",
      "destination": "/api/sale-feed"
    }
  ],
  "crons": [
    {
      "path": "/api/keycrm-sync?action=sync",
      "schedule": "0 6 * * *"
    }
  ]
}
